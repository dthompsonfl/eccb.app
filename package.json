{
  "name": "eccb-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:workers": "tsx src/workers/index.ts",
    "dev:full": "concurrently -n \"next,workers\" -c \"cyan,magenta\" \"next dev --port 3025\" \"tsx src/workers/index.ts\"",
    "build": "next build",
    "build:production": "pnpm run db:generate && next build",
    "start:server": "next start",
    "start:workers": "tsx src/workers/index.ts",
    "lint": "eslint",
    "test": "pnpm run permissions:audit && tsx scripts/assert-no-skipped-tests.ts && vitest",
    "test:run": "pnpm run permissions:audit && tsx scripts/assert-no-skipped-tests.ts && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:smart-upload:fixtures": "tsx scripts/test-smart-upload-fixtures.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --reporter=html,json,line",
    "test:e2e:setup": "playwright test e2e/auth.setup.ts --project=setup",
    "test:all": "pnpm run test:run && pnpm run test:e2e:ci",
    "verify:preview": "tsx scripts/verify-upload-review-preview.ts",
    "check-routes": "tsx scripts/check-routes.ts",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed:production": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "security:audit": "bash scripts/security-audit.sh",
    "security:check": "pnpm audit --audit-level=moderate",
    "security:fix": "pnpm audit --fix",
    "deps:check": "tsx scripts/dependency-check.ts",
    "deps:update": "pnpm outdated && pnpm update --interactive",
    "start:sockets": "tsx src/server/socket-worker.ts",
    "setup": "tsx scripts/verify-env.ts && pnpm run db:generate",
    "start": "next start",
    "start:all": "tsx scripts/start.ts",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test:run && pnpm run build",
    "validate:ci": "pnpm run lint && pnpm run typecheck && pnpm run test:run && pnpm run test:e2e:ci && pnpm run build",
    "permissions:audit": "tsx scripts/assert-canonical-permissions.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.893.0",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^27.0.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "bullmq": "^5.69.1",
    "canvas": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.4",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.14.2",
    "hono": "^4.12.18",
    "input-otp": "^1.4.2",
    "ioredis": "^5.9.3",
    "jsonrepair": "^3.13.2",
    "lucide-react": "^0.563.0",
    "magicast": "^0.3.5",
    "mysql2": "^3.17.2",
    "napi-rs": "^0.3.10",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "pitchy": "^4.1.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.5.7",
    "recharts": "^3.7.0",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "tonal": "^6.0.0",
    "vaul": "^1.1.2",
    "webmidi": "^3.1.14",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@napi-rs/canvas": "^0.1.96",
    "@playwright/test": "^1.58.0",
    "@prisma/config": "^7.5.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tonejs/midi": "^2.0.28",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^15.14.0",
    "jest-canvas-mock": "^2.5.2",
    "jsdom": "^28.1.0",
    "nanoid": "^5.1.6",
    "playwright": "^1.58.0",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "bullmq": {
      "ioredis": "5.9.3"
    },
    "@prisma/dev": {
      "hono": ">=4.12.0",
      "@mrleebo/prisma-ast": "0.14.0"
    },
    "minimatch": ">=10.2.1",
    "@eslint/config-array": ">=0.23.0"
  },
  "packageManager": "pnpm@9.15.9"
}
