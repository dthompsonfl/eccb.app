# ==============================================================================
# ECCB Platform - Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# DEVELOPMENT ENVIRONMENT
# ------------------------------------------------------------------------------
# Safe development values - these are active for local development
NODE_ENV=development
PORT=3025
APP_URL=http://localhost:3025
NEXT_PUBLIC_APP_URL=http://localhost:3025
NEXT_PUBLIC_APP_NAME=Emerald Coast Community Band
APP_VERSION=1.0.0

# ----------------------------------------------------------------------------
# SETUP MODE - required for browser-based initial configuration
# Set to true while running the setup wizard; disable afterwards.
SETUP_MODE=false
# Optional secret token required by the frontend when communicating with
# /api/setup endpoints. Set this in production to prevent unauthorized access.
SETUP_TOKEN=secure-setup-token
# Database & Cache (Development)
DATABASE_URL="mysql://root:Bhg75jfmc!@localhost:3306/eccb_dev"
REDIS_URL="redis://localhost:6379"

# Authentication (Development)
AUTH_SECRET="3730388f04a9e76d300aa6a96b144dd1c4973dd6d9ea5ea3dc7f531002558d36"
BETTER_AUTH_SECRET="7313a9cf7c3f53c44aaaede3db19d0c833c680ed25d47d634de83673fc5e2645"
AUTH_URL="http://localhost:3025"
BETTER_AUTH_URL="http://localhost:3025"
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Super Admin (Development - FOR TESTING ONLY)
SUPER_ADMIN_EMAIL="admin@eccb.app"
SUPER_ADMIN_PASSWORD="Eccb@dm1n2026!"
SUPER_ADMIN_DEFAULT_PASSWORD="Eccb@dm1n2026!"
ADMIN_EMAIL="admin@eccb.app"

# OAuth (Google) - Development
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Storage (Development)
STORAGE_DRIVER=LOCAL
LOCAL_STORAGE_PATH=./storage
MAX_FILE_SIZE=52428800

# S3 Configuration (Development - when STORAGE_DRIVER=S3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=eccb-storage
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Email (Development)
EMAIL_PROVIDER=LOG
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=noreply@eccb.app

# Push Notifications (Development)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Virus Scanning (Development)
ENABLE_VIRUS_SCAN=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Logging (Development)
LOG_DIR=./logs
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=100
LOG_ROTATION=daily

# Workers & Process Management (Development)
WORKER_HEALTH_PORT=3001
PROCESS_MANAGER_HEALTH_PORT=3002
RESTART_CRASHED_PROCESSES=false
SCHEDULER_INTERVAL_MS=60000
CLEANUP_INTERVAL_MS=86400000
ENABLE_WORKER=true
ENABLE_PROCESS_MANAGER=true

ENABLE_WEBSOCKETS=true
SOCKET_PORT=3005

# ------------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT
# ------------------------------------------------------------------------------
# Production values - uncomment and replace with your production values
# NODE_ENV=production
# PORT=3000
# APP_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_NAME=Emerald Coast Community Band
# APP_VERSION=1.0.0

# Database & Cache (Production)
# DATABASE_URL="mysql://your_db_user:your_secure_password@your_db_host:3306/your_db_name"
# REDIS_URL="redis://your_redis_host:6379"

# Authentication (Production)
# AUTH_SECRET="your_32_char_auth_secret_here"
# BETTER_AUTH_SECRET="your_32_char_better_auth_secret_here"
# AUTH_URL="https://yourdomain.com"
# BETTER_AUTH_URL="https://yourdomain.com"
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Super Admin (Production - REMOVE AFTER INITIAL SETUP)
# SUPER_ADMIN_EMAIL="admin@yourdomain.com"
# SUPER_ADMIN_PASSWORD="your_secure_admin_password"
# SUPER_ADMIN_DEFAULT_PASSWORD="your_secure_admin_password"
# ADMIN_EMAIL="admin@yourdomain.com"

# OAuth (Google) - Production
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Storage (Production)
# STORAGE_DRIVER=S3
# LOCAL_STORAGE_PATH=./storage
# MAX_FILE_SIZE=52428800

# S3 Configuration (Production)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET_NAME=your-production-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your_aws_access_key
# S3_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_FORCE_PATH_STYLE=false

# Email (Production)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_SECURE=false
# SMTP_FROM=noreply@yourdomain.com

# Push Notifications (Production)
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key

# Virus Scanning (Production)
# ENABLE_VIRUS_SCAN=true
# CLAMAV_HOST=your_clamav_host
# CLAMAV_PORT=3310

# Logging (Production)
# LOG_DIR=./logs
# LOG_RETENTION_DAYS=30
# LOG_MAX_SIZE_MB=500
# LOG_ROTATION=daily

# Workers & Process Management (Production)
# WORKER_HEALTH_PORT=3001
# PROCESS_MANAGER_HEALTH_PORT=3002
# RESTART_CRASHED_PROCESSES=true
# SCHEDULER_INTERVAL_MS=300000
# CLEANUP_INTERVAL_MS=86400000
# ENABLE_WORKER=true
# ENABLE_PROCESS_MANAGER=true


# ------------------------------------------------------------------------------
# SMART UPLOAD (AI-Powered File Processing)
# ------------------------------------------------------------------------------
# [Required: No] Enable Smart Upload feature (true/false)
SMART_UPLOAD_ENABLED="true"
# [Required: No] Maximum number of files per upload (default: 20)
# SMART_UPLOAD_MAX_FILES="20"
# [Required: No] Maximum total bytes for batch upload (default: 500MB = 524288000)
SMART_UPLOAD_MAX_TOTAL_BYTES="524288000"
# [Required: No] OCR mode for PDF processing
# Options: pdf_text (built-in), tesseract, ocrmypdf, vision_api
SMART_UPLOAD_OCR_MODE="pdf_text"

# ------------------------------------------------------------------------------
# AI / LLM PROVIDER CONFIGURATION
# ============================================================================
# This configuration is database-driven! Set these env vars to seed the
# database on first run. After that, manage settings via the admin UI.
# ============================================================================

# [Required: No] LLM Provider - options: ollama, openai, anthropic, gemini, openrouter, custom
# Default: ollama (local/free) - good for testing without external APIs
# For production use: openrouter or gemini (free tier available)
LLM_PROVIDER="openrouter"

# [Required: No] Custom endpoint URL (leave empty to use provider defaults)
# Examples: https://openrouter.ai/api/v1, http://localhost:11434, https://api.anthropic.com
LLM_ENDPOINT_URL=""

# [Deprecated] Use LLM_ENDPOINT_URL instead
LLM_OLLAMA_ENDPOINT="http://localhost:11434"

# [Required: No] Vision model name (for first-pass extraction)
# Defaults vary by provider. Examples:
#   openrouter: "google/gemini-2.0-flash-exp:free" (free), "openai/gpt-4o", "meta-llama/llama-2-vision"
#   gemini: "gemini-2.0-flash-exp"
#   openai: "gpt-4o"
#   anthropic: "claude-3-5-sonnet-20241022"
#   ollama: "llama3.2-vision"
LLM_VISION_MODEL=""

# [Required: No] Verification model (for second-pass validation)
# Defaults vary by provider. Examples:
#   openrouter: "google/gemma-3-27b-it:free" (free), "meta-llama/llama-2-7b"
#   ollama: "qwen2.5:7b"
LLM_VERIFICATION_MODEL=""

# ============================================================================
# API KEY CONFIGURATION
# ============================================================================

# OpenAI API key (required if LLM_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
LLM_OPENAI_API_KEY=""

# Anthropic API key (required if LLM_PROVIDER=anthropic)
# Get from: https://console.anthropic.com/keys
# Format: sk-ant-...
LLM_ANTHROPIC_API_KEY=""

# Google Gemini API key (required if LLM_PROVIDER=gemini)
# Get from: https://aistudio.google.com/app/apikey
# Format: AIza...
# NOTE: Managed via Admin UI → Smart Upload Settings (stored in database).
# Set here ONLY for one-time bootstrapping; value is seeded to DB on first run.
LLM_GEMINI_API_KEY=""

# OpenRouter API key (required if LLM_PROVIDER=openrouter)
# Get from: https://openrouter.ai/keys
# Format: sk-or-...
# NOTE: Managed via Admin UI → Smart Upload Settings (stored in database).
# Set here ONLY for one-time bootstrapping; value is seeded to DB on first run.
LLM_OPENROUTER_API_KEY=""

# Custom API key (for OpenAI-compatible endpoints like Ollama, LM Studio, Groq, etc.)
LLM_CUSTOM_API_KEY=""

# ============================================================================
# BEHAVIOR & LIMITS (Optional - defaults provided in code)
# ============================================================================

# Confidence score threshold for second-pass (0-100, default: 60)
# LLM_SKIP_PARSE_THRESHOLD="60"

# Auto-approve threshold (0-100, default: 90)
# LLM_AUTO_APPROVE_THRESHOLD="90"

# Rate limit in requests per minute (default: 15)
# LLM_RATE_LIMIT_RPM="15"

# Enable two-pass verification (default: true)
# LLM_TWO_PASS_ENABLED="true"

# ------------------------------------------------------------------------------
# DIGITAL MUSIC STAND
# ------------------------------------------------------------------------------
# [Required: No] OMR (Optical Music Recognition) provider override: openai, anthropic, gemini
# Falls back to LLM_PROVIDER if not set
OMR_PROVIDER=""

# Feature Flags (set to 'false' or '0' to disable)
# [Required: No] Master toggle for the Digital Music Stand
FEATURE_MUSIC_STAND="true"
# [Required: No] Practice timer / practice log tracking
FEATURE_PRACTICE_TRACKING="true"
# [Required: No] Real-time WebSocket sync (vs polling-only)
FEATURE_STAND_WEBSOCKET_SYNC="false"
# [Required: No] Audio-synced score playback (planned)
FEATURE_STAND_AUDIO_SYNC="false"
# [Required: No] Offline PWA caching for stand PDFs
FEATURE_STAND_OFFLINE="false"

# ------------------------------------------------------------------------------
# ENCRYPTION
# ------------------------------------------------------------------------------
# Encryption key for sensitive data (64 hex characters / 32 bytes for AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef